{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "baseUrl": ".",
    "paths": {
      "cors": ["src/shims/cors"],
      "express": ["src/shims/express"],
      "dotenv": ["src/shims/dotenv"],
      "multer": ["src/shims/multer"],
      "socket.io": ["src/shims/socket-io"],
      "@supabase/supabase-js": ["src/shims/supabase-js"],
      "zod": ["src/shims/zod"],
      "tesseract.js": ["src/shims/tesseract-js"],
      "node:path": ["src/shims/node-path"],
      "node:http": ["src/shims/node-http"],
      "node:fs": ["src/shims/node-fs"],
      "node:fs/promises": ["src/shims/node-fs-promises"],
      "node:crypto": ["src/shims/node-crypto"],
      "node:buffer": ["src/shims/node-buffer"]
    },
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["dist", "node_modules", "../prodsync-app"]
}
